      ]
    },
    {
      "gate_id": "conversion_findings",
      "description": "SSI and Blocks Engine transformer diagnostics must not include actionable conversion findings.",
      "metrics": [
        "conversion_findings"
      ]
    },
    {
      "gate_id": "visual_parity",
      "description": "Visual parity artifact must report no mismatches or delta.",
      "metrics": [
