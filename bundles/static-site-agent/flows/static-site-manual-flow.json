{
    "max_items": {},
    "name": "Static Site — Manual",
    "pipeline_slug": "static-site-pipeline",
    "schedule": "manual",
    "schema_version": 1,
    "slug": "static-site-manual-flow",
    "steps": [
        {
            "config_patch_queue": [],
            "disabled_tools": [],
            "enabled": true,
            "handler_slugs": [
                "github"
            ],
            "handler_configs": {
                "github": {
                    "data_source": "issues",
                    "labels": "status:design-ready",
                    "exclude_labels": "status:built,status:abandoned",
                    "max_items": 5,
                    "repo": "chubes4/wp-site-generator",
                    "state": "open"
                }
            },
            "prompt_queue": [],
            "queue_mode": "static",
            "step_position": 0,
            "step_type": "fetch"
        },
        {
            "completion_assertions": {
                "complete_when_any": [
                    {
                        "name": "static_site_pr",
                        "tools": [
                            {
                                "name": "github_pull_request_publish",
                                "required_output": "html_url",
                                "success": true
                            }
                        ]
                    }
                ]
            },
            "disabled_tools": [
                "reject_source",
                "defer_item"
            ],
            "handler_configs": {},
            "prompt_queue": [
                {
                    "added_at": "2026-05-09T22:00:00+00:00",
                    "prompt": "Implement the fetched concept as a static site. Read both the issue body (concept) and the design agent's most recent comment (design direction) — both are sources of truth. Honor them. Do not invent a different concept and do not override the design."
                },
                {
                    "added_at": "2026-05-13T12:35:00+00:00",
                    "prompt": "Set the pull request target lane from the fetched issue labels when calling github_pull_request_publish. If the issue has commerce:woocommerce or site-kind:commerce, pass labels [\"target:woocommerce\"]. If the issue has commerce:none or site-kind:content, pass labels [\"target:wordpress\"]. Use exactly one target label. The target label describes the WordPress import lane; static-sites/ remains only the source-file location."
                },
                {
                    "added_at": "2026-05-31T18:40:00+00:00",
                    "prompt": "Use the fetched issue content and its Latest Comment section as the concept and design context. After you have those two inputs, proceed directly to github_pull_request_publish with a files array containing the complete static site implementation."
                }
            ],
            "queue_mode": "static",
            "step_position": 1,
            "step_type": "ai"
        },
        {
            "disabled_tools": [],
            "enabled": true,
            "handler_configs": {
                "github_pull_request": {
                    "base": "main",
                    "draft": false,
                    "maintainer_can_modify": false,
                    "repo": "chubes4/wp-site-generator"
                }
            },
            "handler_slugs": [
                "github_pull_request"
            ],
            "prompt_queue": [],
            "queue_mode": "static",
            "step_position": 2,
            "step_type": "publish"
        }
    ]
}
