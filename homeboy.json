{
    "id": "wp-site-generator",
    "name": "WP Site Generator",
    "extensions": {
        "wordpress": {
            "settings": {
                "wordpress_runtime_blueprint": {
                    "$schema": "https://playground.wordpress.net/blueprint-schema.json",
                    "preferredVersions": {
                        "php": "8.3",
                        "wp": "latest"
                    },
                    "steps": [
                        {
                            "step": "installPlugin",
                            "pluginData": {
                                "resource": "git:directory",
                                "url": "https://github.com/Automattic/blocks-engine",
                                "ref": "php-transformer-v0.1.0",
                                "refType": "tag",
                                "path": "php-transformer"
                            },
                            "options": {
                                "activate": true,
                                "targetFolderName": "blocks-engine-php-transformer"
                            }
                        },
                        {
                            "step": "installPlugin",
                            "pluginData": {
                                "resource": "git:directory",
                                "url": "https://github.com/chubes4/static-site-importer",
                                "ref": "main",
                                "refType": "branch"
                            },
                            "options": {
                                "activate": true,
                                "targetFolderName": "static-site-importer"
                            }
                        }
                    ]
                }
            }
        }
    }
}
